<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.Revistasuteq" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/primary_uteq</item>
        <item name="colorPrimaryVariant">@color/primary_dark_uteq</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/accent_uteq</item>
        <item name="colorSecondaryVariant">@color/primary_dark_uteq</item>
        <item name="colorOnSecondary">@color/white</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/primary_dark_uteq</item>
        <!-- Background color. -->
        <item name="android:windowBackground">@color/background_uteq</item>
    </style>
</resources>